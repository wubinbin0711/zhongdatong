{
  "name": "codenest-hero",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "build": "tsc -b && vite build",
    "build:api": "tsc -p server/tsconfig.json",
    "start:api": "node server/dist/index.js",
    "start:web": "vite preview --host 0.0.0.0 --port 4173",
    "preview": "vite preview",
    "account:create": "tsx server/src/scripts/create-account.ts",
    "prisma:generate": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema server/prisma/schema.prisma"
  },
  "dependencies": {
    "ali-oss": "^6.22.0",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "hls.js": "^1.5.17",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "tsx": "^4.19.4",
    "vite": "^5.4.10"
  }
}
